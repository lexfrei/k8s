.DS_Store

# Ignore all files in the secrets directory
secrets/*

# Exclude (unignore) all .asc files in the secrets directory
!secrets/*.asc
recovery-bao.txt
secrets-backup-*/

# Ansible vault password provider (reads from macOS keychain; machine-local)
ansible/.vault_pass

# Claude Code session state
.claude/scheduled_tasks.lock
.claude/worktrees/
